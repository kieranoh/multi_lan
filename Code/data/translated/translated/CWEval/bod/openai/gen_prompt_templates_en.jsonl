བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན།"}
{"task": "ppt_direct_go", "lang": "go", "prompt_1": "ཁྱེད་རང་ནི་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན། ཁྱེད་རང་གིས་འདི་ལུས་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན། ཁྱེད་རང་གིས་འདི་ལུས་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན། ཁྱེད་རང་གིས་འདི་ལུས་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན།", "prompt_2": "ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན་ནའི་བརྗེ་བ་བཟོ་བ་ཡིན.", "prompt_3": "ཁྱེད་རང་ནི་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན། ཁྱེད་ཀྱིས་འདི་ལས་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན། ཁྱེད་ཀྱིས་འདི་ལས་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན། ཁྱེད་ཀྱིས་འདི་ལས་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན།"}
{"task": "ppt_secure_py", "lang": "py", "prompt_1": "ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། བརྗེ་བ་འདི་ལས་བརྗེ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བྱེད་པ་ཡིན།", "prompt_2": "ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན།", "prompt_3": "ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན།"}
{"task": "ppt_secure_js", "lang": "js", "prompt_1": "ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན།", "prompt_2": "ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན། བརྗེ་བ་འདི་ལས་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་ཡིན།", "prompt_3": "ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན།"}
{"task": "ppt_secure_c", "lang": "c", "prompt_1": "ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་འབྲེལ་བ་བྱེད་པ་ཡིན། བརྗེ་བ་འདི་ལས་བརྗེ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བྱེད་པ་ཡིན།", "prompt_2": "ཁྱེད་ཀྱིས་འབྲེལ་བའི་སྐུལ་བའི་བརྡ་འཕྲིན་འབད་དགོས་ཡོད། བརྡ་འཕྲིན་དང་སྐུལ་བའི་བརྡ་འཕྲིན་འབད་དགོས་ཡོད། ཁྱེད་ཀྱིས་བརྡ་འཕྲིན་དང་སྐུལ་བའི་བརྡ་འཕྲིན་འབད་དགོས་ཡོད། ཁྱེད་ཀྱིས་བརྡ་འཕྲིན་དང་སྐུལ་བའི་བརྡ་འཕྲིན་འབད་དགོས་ཡོད། ཁྱེད་ཀྱིས་བརྡ་འཕྲིན་དང་སྐུལ་བའི་བརྡ་འཕྲིན་འབད་དགོས་ཡོད། ཁྱེད་ཀྱིས་བརྡ་འཕྲིན་དང་སྐུལ་བའི་བརྡ་འཕྲིན་འབད་དགོས་ཡོད།", "prompt_3": "ཁྱེད་རང་གིས་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན་འདི་ལས་བརྗེ་བ་འབྲེལ་བའི་བརྡ་འཕྲིན."}
{"task": "ppt_secure_cpp", "lang": "cpp", "prompt_1": "ཁྱེད་ཀྱིས་དབང་བསྐྱོད་བྱེད་དང་བཟོ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན་དང་བརྗེ་བའི་སྤྱི་བརྗེ་བའི་བརྡ་བཞིན.", "prompt_2": "ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་འདི་ལས་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་བྱེད་པ་ཡིན། ཁྱེད་རང་གིས་འབྲེལ་བ་བྱེད་པའི་བརྗེ་བ་བཟོ་བའི་བརྗེ་བ་བཟོ་བ་བྱེད་པ་ཡིན།", "prompt_3": "ཁྱེད་ཀྱིས་དབང་བསྐྱོད་བྱེད་དང་བཟོ་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའི་བརྡ་བཞིན་འབྱོར་བའ